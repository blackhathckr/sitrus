// Sitrus Social Commerce Platform — Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  CREATOR
}

enum Marketplace {
  MYNTRA
  FLIPKART
  AJIO
  AMAZON
}

enum EarningStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  CLICK
  PAYOUT_APPROVE
  PAYOUT_REJECT
}

// =============================================================================
// USER
// =============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  password      String?
  name          String
  role          UserRole  @default(CREATOR)
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // OAuth
  googleId String? @unique
  image    String?

  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Relations
  creatorProfile CreatorProfile?
  links          Link[]
  earnings       Earning[]
  payouts        Payout[]
  collections    Collection[]
  auditLogs      AuditLog[]
  brandOrders    BrandOrder[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([googleId])
  @@map("users")
}

// =============================================================================
// CREATOR PROFILE
// =============================================================================

model CreatorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Profile
  instagramHandle String?
  bio             String? @db.Text
  slug            String  @unique

  // Storefront customization
  avatarUrl   String?
  bannerUrl   String?
  displayName String?
  tagline     String?

  // Social links
  youtubeUrl String?
  twitterUrl String?

  // Status
  isApproved Boolean @default(false)
  isPublic   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([instagramHandle])
  @@index([isApproved])
  @@map("creator_profiles")
}

// =============================================================================
// BRAND
// =============================================================================

model Brand {
  id              String  @id @default(cuid())
  name            String  @unique
  slug            String  @unique
  registeredName  String?
  displayName     String?
  logoUrl         String?
  gstin           String? @unique
  contactPOC      String?
  contactPhone    String?
  isActive        Boolean @default(true)

  // Brand integration metadata
  commissionRate Float?  // Default commission rate for creators (e.g. 10.0 = 10%)
  websiteUrl     String? // Brand's consumer-facing website (e.g. https://izfworld.com)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products    Product[]
  integration BrandIntegration?
  orders      BrandOrder[]

  @@index([name])
  @@index([isActive])
  @@map("brands")
}

// =============================================================================
// PRODUCT CATALOG
// =============================================================================

model Product {
  id            String       @id @default(cuid())
  title         String
  description   String?      @db.Text
  imageUrl      String
  images        String[]     @default([])
  price         Float
  originalPrice Float?
  currency      String       @default("INR")
  sourceUrl     String
  marketplace   Marketplace?
  category      String
  subCategory   String?
  brand         String?
  brandId       String?
  brandRef      Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)
  rating        Float?
  reviewCount   Int?
  inStock       Boolean      @default(true)
  isActive      Boolean      @default(true)

  // Affiliate metadata
  affiliateBaseUrl String?
  commissionRate   Float?

  // EasyEcom sync fields (for brand-sourced products)
  easyecomProductId String? @unique // EasyEcom cp_id
  easyecomSku       String?         // EasyEcom SKU code
  stockQuantity     Int?            // Actual stock count from EasyEcom

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  links              Link[]
  collectionProducts CollectionProduct[]

  @@index([marketplace])
  @@index([category])
  @@index([isActive])
  @@index([brand])
  @@index([brandId])
  @@index([easyecomProductId])
  @@map("products")
}

// =============================================================================
// AFFILIATE LINKS (SitLinks)
// =============================================================================

model Link {
  id        String  @id @default(cuid())
  creatorId String
  creator   User    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  shortCode    String  @unique
  customAlias  String? @unique
  affiliateUrl String
  isActive     Boolean @default(true)

  // Denormalized for performance
  totalClicks Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clicks      Click[]
  earnings    Earning[]
  brandOrders BrandOrder[]

  @@index([creatorId])
  @@index([productId])
  @@index([shortCode])
  @@index([customAlias])
  @@map("links")
}

// =============================================================================
// CLICK TRACKING
// =============================================================================

model Click {
  id     String @id @default(cuid())
  linkId String
  link   Link   @relation(fields: [linkId], references: [id], onDelete: Cascade)

  ipHash    String? // Hashed IP for privacy
  userAgent String? @db.Text
  referrer  String?
  country   String?
  city      String?
  device    String? // mobile, desktop, tablet
  browser   String?
  os        String?

  createdAt DateTime @default(now())

  @@index([linkId])
  @@index([createdAt])
  @@index([country])
  @@map("clicks")
}

// =============================================================================
// COLLECTIONS
// =============================================================================

model Collection {
  id        String @id @default(cuid())
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  name        String
  description String? @db.Text
  coverImage  String?
  slug        String
  isPublic    Boolean @default(true)
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products CollectionProduct[]

  @@unique([creatorId, slug])
  @@index([creatorId])
  @@map("collections")
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  order        Int        @default(0)

  addedAt DateTime @default(now())

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
  @@map("collection_products")
}

// =============================================================================
// EARNINGS
// =============================================================================

model Earning {
  id        String @id @default(cuid())
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  linkId    String?
  link      Link?  @relation(fields: [linkId], references: [id], onDelete: SetNull)

  amount      Float
  currency    String        @default("INR")
  status      EarningStatus @default(PENDING)
  period      String // "2026-02", "2026-W06"
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([linkId])
  @@index([status])
  @@index([period])
  @@map("earnings")
}

// =============================================================================
// PAYOUTS
// =============================================================================

model Payout {
  id        String @id @default(cuid())
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  amount      Float
  currency    String       @default("INR")
  status      PayoutStatus @default(PENDING)
  method      String? // upi, bank_transfer
  approvedBy  String?
  processedAt DateTime?
  reference   String? // Transaction reference

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([status])
  @@map("payouts")
}

// =============================================================================
// AUDIT LOG
// =============================================================================

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String
  changes    Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// BRAND INTEGRATION (EasyEcom / external OMS credentials)
// =============================================================================

model BrandIntegration {
  id      String @id @default(cuid())
  brandId String @unique
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  provider    String  // "easyecom" | "shopify" | "custom"
  apiKeyEnc   String  @db.Text // AES-256-GCM encrypted x-api-key
  emailEnc    String  @db.Text // AES-256-GCM encrypted API user email
  passwordEnc String  @db.Text // AES-256-GCM encrypted API user password
  locationKey String            // Location ID (not secret)

  // Cached JWT token (encrypted)
  jwtTokenEnc    String?   @db.Text
  tokenExpiresAt DateTime?

  // Shopify storefront (for product URL mapping)
  shopifyTokenEnc      String?  @db.Text // AES-256-GCM encrypted Shopify Admin API access token
  shopifyDomain        String?           // e.g. "i-z-f.myshopify.com"
  shopifyClientId      String?           // Client ID for token refresh
  shopifyClientSecEnc  String?  @db.Text // AES-256-GCM encrypted Client Secret
  shopifyTokenExpiry   DateTime?         // Token expiry (24h)

  // Sync state
  lastProductSync   DateTime?
  lastInventorySync DateTime?
  lastOrderSync     DateTime?
  syncEnabled       Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brand_integrations")
}

// =============================================================================
// BRAND ORDERS (orders tracked from external brands via EasyEcom)
// =============================================================================

model BrandOrder {
  id      String @id @default(cuid())
  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  // EasyEcom reference
  easyecomOrderId   String  @unique
  easyecomInvoiceId String?

  // Attribution — which creator's SitLink drove this order
  creatorId   String?
  creator     User?   @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  linkId      String?
  link        Link?   @relation(fields: [linkId], references: [id], onDelete: SetNull)
  utmSource   String?
  utmCampaign String? // Creator slug for attribution
  utmMedium   String?
  utmContent  String? // SitLink shortCode for attribution

  // Order details
  orderNumber   String
  customerName  String?
  customerEmail String?
  orderValue    Float
  currency      String @default("INR")
  status        String // placed, confirmed, dispatched, delivered, cancelled, returned
  itemCount     Int    @default(1)

  orderedAt   DateTime
  fulfilledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  items BrandOrderItem[]

  @@index([brandId])
  @@index([creatorId])
  @@index([linkId])
  @@index([status])
  @@index([orderedAt])
  @@map("brand_orders")
}

// =============================================================================
// BRAND ORDER ITEMS
// =============================================================================

model BrandOrderItem {
  id      String     @id @default(cuid())
  orderId String
  order   BrandOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  easyecomProductId String?
  sku               String?
  productName       String
  quantity          Int
  unitPrice         Float
  totalPrice        Float

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("brand_order_items")
}
